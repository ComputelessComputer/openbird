---
interface Props {
  description: string;
  title?: string;
}

const {
  description,
  title = "Openbird | Local-first macOS activity journal",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07090c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #07090c;
    --bg-soft: #0d1015;
    --panel: rgba(17, 21, 28, 0.92);
    --panel-strong: #11161d;
    --ink: #f4f1e8;
    --muted: #9ca5b2;
    --muted-strong: #c2c9d2;
    --line: rgba(255, 255, 255, 0.11);
    --line-strong: rgba(255, 255, 255, 0.18);
    --accent: #8cf98d;
    --accent-soft: rgba(140, 249, 141, 0.14);
    --warm: #ff8a5c;
    --warm-soft: rgba(255, 138, 92, 0.14);
    --shadow: 0 32px 80px rgba(0, 0, 0, 0.45);
    --content-width: min(1120px, calc(100vw - 2rem));
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    font-family: "IBM Plex Mono", monospace;
    color: var(--ink);
    background:
      radial-gradient(circle at top, rgba(140, 249, 141, 0.12), transparent 28%),
      radial-gradient(circle at 80% 20%, rgba(255, 138, 92, 0.12), transparent 20%),
      linear-gradient(180deg, #090b0f 0%, #07090c 100%);
    line-height: 1.65;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.6), transparent 85%);
    opacity: 0.4;
  }

  ::selection {
    background: rgba(140, 249, 141, 0.25);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .container {
    width: var(--content-width);
    margin: 0 auto;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent), var(--warm));
    box-shadow: 0 0 24px rgba(140, 249, 141, 0.45);
  }

  .serif {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1,
  h2,
  h3 {
    font-weight: 500;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.95;
  }

  h1 {
    font-size: clamp(4rem, 12vw, 8.6rem);
  }

  h2 {
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  h3 {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
  }

  p {
    color: var(--muted);
    font-size: clamp(0.98rem, 1.2vw, 1.05rem);
  }

  section {
    padding: 2rem 0 4.5rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0.92rem 1.15rem;
    border: 1px solid var(--line-strong);
    border-radius: 0.4rem;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.34);
  }

  .button-primary {
    background: var(--ink);
    color: var(--bg);
  }

  .button-secondary {
    background: rgba(255, 255, 255, 0.02);
    color: var(--muted-strong);
  }

  .terminal {
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 22%),
      var(--panel);
    box-shadow: var(--shadow);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.8rem;
    padding: 0 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .terminal-dots {
    display: flex;
    gap: 0.4rem;
  }

  .terminal-dots span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .terminal-dots span:nth-child(1) {
    background: rgba(255, 138, 92, 0.85);
  }

  .terminal-dots span:nth-child(2) {
    background: rgba(255, 210, 87, 0.85);
  }

  .terminal-dots span:nth-child(3) {
    background: rgba(140, 249, 141, 0.85);
  }

  .section-head {
    display: grid;
    gap: 1rem;
    max-width: 46rem;
    margin-bottom: 2rem;
  }

  .section-rule {
    padding: 0;
  }

  .section-rule .container {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-rule .container::after {
    content: "";
    flex: 1 1 auto;
    height: 1px;
    background: var(--line);
  }

  .grid-2,
  .grid-3 {
    display: grid;
    gap: 1rem;
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .fade-up {
    opacity: 0;
    transform: translateY(18px);
    animation: fade-up 680ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .fade-up.delay-1 {
    animation-delay: 120ms;
  }

  .fade-up.delay-2 {
    animation-delay: 240ms;
  }

  .fade-up.delay-3 {
    animation-delay: 360ms;
  }

  @keyframes fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 960px) {
    .grid-2,
    .grid-3 {
      grid-template-columns: 1fr;
    }

    section {
      padding-bottom: 3.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
