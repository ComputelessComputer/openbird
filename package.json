{
  "name": "openbird",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "landing:dev": "bun run --filter @openbird/landing dev",
    "landing:build": "bun run --filter @openbird/landing build",
    "landing:preview": "bun run --filter @openbird/landing preview"
  }
}
